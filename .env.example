# Copy to .env.local and fill in from your Supabase project dashboard
# Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...your-anon-public-key

# Voice note -> expense (Google Gemini). Get a key from https://aistudio.google.com/apikey
# Has a generous free tier. Set this in Vercel project env too (server only, NOT NEXT_PUBLIC).
GEMINI_API_KEY=your-gemini-api-key
# Optional: override the model (default: gemini-3.1-flash-lite)
# More accurate (pricier): gemini-2.5-flash | Cheapest: gemini-2.5-flash-lite
# GEMINI_MODEL=gemini-3.1-flash-lite
