# Copy to .env.local and fill in from your Supabase project dashboard
# Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...your-anon-public-key

# --- Groq (untuk voice transcribe) ---
# Daftar gratis di https://console.groq.com → Create API Key
GROQ_API_KEY=gsk_your-groq-api-key

# --- DeepSeek (untuk financial advisor + chat) ---
# Daftar di https://platform.deepseek.com → API Keys
DEEPSEEK_API_KEY=sk_your-deepseek-api-key
# Optional: override model (default: deepseek-chat)
# DEEPSEEK_MODEL=deepseek-chat
